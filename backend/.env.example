# Study Note Backend 환경변수 예시
# 실제 값은 .env에 설정하며 Git에 커밋하지 않는다.

# 서버
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=study-note-dev-secret-change-in-production

# SQLite DB 경로 (개발)
STUDY_NOTE_DB_FILE=./study-note.db

# Google OAuth2 (로컬 테스트용)
# Google Cloud Console → OAuth2 앱 → Client ID/Secret 발급 후 입력
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# SSO 콜백 URL — 로컬 테스트 시 아래 값 사용
# 운영 환경: https://study-note.yuna-pa.com/api/auth/sso/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/sso/google/callback

# 프론트엔드 기준 URL — SSO 콜백 후 리다이렉트 대상
# 운영 환경: https://study-note.yuna-pa.com
APP_BASE_URL=http://localhost:5173

# CORS 허용 출처 (쉼표 구분, 미설정 시 기본값 적용)
# 운영 환경: https://study-note.yuna-pa.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# 속도 제한 (선택, 기본: 15분 창 / 최대 20회)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=20
